# Environment template for the LLM rationality eval and the LLM Showcase scenarios.
# Copy this file to `.env` and fill in your own values:
#
#     cp .env.example .env
#
# Only needed for the LLM features (the `[eval]` extras, `demo5.yaml`, `llm5_only.yaml`,
# and the offline eval). The engine, terminal CLI, browser dashboard, and the test
# suite all run WITHOUT a `.env`.
#
# Auth uses Vertex AI via Application Default Credentials (ADC) — there is NO API key in
# this file. Authenticate your machine once with:
#
#     gcloud auth application-default login
#
# Then enable the Vertex AI API on the project below.

# Route the google-genai SDK through Vertex AI (vs. the public Gemini API).
GOOGLE_GENAI_USE_VERTEXAI=true

# Your Google Cloud project id (the one with Vertex AI enabled).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI location. `global` works for the Gemini models used here.
GOOGLE_CLOUD_LOCATION=global

# Model id used by the agents and the eval.
GEMINI_MODEL=gemini-3.5-flash
