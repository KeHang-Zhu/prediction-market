# Environment template for the LLM rationality eval and the LLM Showcase scenarios.
# Copy this file to `.env` and fill in your own values:
#
#     cp .env.example .env
#
# Only needed for the LLM features (the `[eval]` extras, `demo5.yaml`, `llm5_only.yaml`,
# and the offline eval). The engine, terminal CLI, browser dashboard, and the test
# suite all run WITHOUT a `.env`.
#
# Auth uses Vertex AI via Application Default Credentials (ADC) — there is NO API key in
# this file. Authenticate your machine once with:
#
#     gcloud auth application-default login
#
# Then enable the Vertex AI API on the project below.

# Route the google-genai SDK through Vertex AI (vs. the public Gemini API).
GOOGLE_GENAI_USE_VERTEXAI=true

# Your Google Cloud project id (the one with Vertex AI enabled).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI location. `global` works for the Gemini models used here.
GOOGLE_CLOUD_LOCATION=global

# Model id used by the agents and the eval.
GEMINI_MODEL=gemini-3.5-flash

# --- OpenAI-compatible providers (DeepSeek / OpenAI / OpenRouter / local vLLM) ---
# Only needed when an agent uses a non-Gemini model. An agentic agent picks its provider
# from its params (e.g. params: {provider: deepseek, model: deepseek-v4-pro}); when
# `provider` is omitted it is inferred from the model name (deepseek* / gpt* / gemini*).
# Different agents in one run may use different models/providers.

# DeepSeek — use a TOOL-CAPABLE model for the agentic loop (deepseek-v4-pro / deepseek-v4-flash),
# NOT deepseek-reasoner.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI — leave OPENAI_BASE_URL blank to use the default api.openai.com endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# OpenRouter / local vLLM (optional):
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=
